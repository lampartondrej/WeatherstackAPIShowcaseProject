<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - ShowcaseProject.Web</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/mobile_tablet.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/mobile_phone.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/ShowcaseProject.Web.styles.css" asp-append-version="true" />
</head>
<body id="dynamic-body">
    <!-- Location Popup Overlay -->
    <div id="location-popup-overlay" class="popup-overlay hidden">
        <div class="glass-popup">
            <h2 class="popup-title" id="popup-title">Welcome!</h2>
            <p class="popup-subtitle" id="popup-subtitle">Enter your location to get weather data</p>
            <div class="popup-input-group">
                <input type="text" id="location-input" class="glass-input" placeholder="Enter city name (e.g., Prague)" autocomplete="off" />
            </div>
            <button id="save-location-btn" class="glass-button">Get Weather</button>
        </div>
    </div>

    <nav class="glass-navbar">
        <a href="/" class="nav-tab active" data-tab="current">Current Weather</a>
        <a href="/" class="nav-tab" data-tab="forecast">Weather Forecast</a>
        <div class="nav-divider"></div>
        <button id="change-location-btn" class="nav-location-btn" title="Change Location">
            <span class="location-icon">📍</span>
            <span id="current-location-display" class="location-text">Loading...</span>
        </button>
    </nav>

    <main role="main">
        @RenderBody()
    </main>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>